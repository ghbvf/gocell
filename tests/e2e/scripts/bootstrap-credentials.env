# tests/e2e/scripts/bootstrap-credentials.env
#
# !!! THIS IS A CI/E2E FIXTURE — NOT A PRODUCTION SECRET !!!
#
# Single source of truth for bootstrap credentials shared by:
#   - tests/e2e/scripts/bootstrap-admin.sh   (sourced by the runner shell to
#                                              issue HTTP Basic Auth on the
#                                              POST /api/v1/access/setup/admin
#                                              call against the corebundle
#                                              service brought up by compose.)
#   - tests/e2e/docker-compose.e2e.yaml     (env_file injects the same values
#                                              into the corebundle container so
#                                              auth.NewBootstrapMiddleware
#                                              accepts the operator request.)
#
# The credentials are scoped to a throwaway docker-compose stack that is torn
# down with `docker compose down -v` after every CI run; no persistence.
#
# To rotate, change the values here and rerun the e2e workflow — both the
# server and the bootstrap script pick the new values up from the same file.
GOCELL_BOOTSTRAP_ADMIN_USERNAME=e2e-bootstrap-admin
GOCELL_BOOTSTRAP_ADMIN_PASSWORD=e2e-bootstrap-password-32!!
