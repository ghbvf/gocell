{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "http.auth.login.v1.response",
  "type": "object",
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "accessToken": {
          "type": "string"
        },
        "refreshToken": {
          "type": "string"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "sessionId": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "passwordResetRequired": {
          "type": "boolean"
        }
      },
      "required": [
        "accessToken",
        "refreshToken",
        "expiresAt",
        "sessionId",
        "userId",
        "passwordResetRequired"
      ]
    }
  },
  "required": [
    "data"
  ]
}
