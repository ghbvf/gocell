{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "http.auth.user.get.v1.response",
  "type": "object",
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "passwordResetRequired": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "username",
        "email",
        "status",
        "createdAt",
        "updatedAt",
        "passwordResetRequired"
      ]
    }
  },
  "required": [
    "data"
  ]
}
