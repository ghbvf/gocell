{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "http.config.update.v1.request",
  "type": "object",
  "properties": {
    "value": { "type": "string", "minLength": 0, "maxLength": 4096 },
    "expectedVersion": {
      "type": "integer",
      "minimum": 1,
      "maximum": 99999,
      "description": "Compare-and-swap guard. Must equal the entry's current version; mismatch returns 409 ERR_VERSION_CONFLICT."
    }
  },
  "required": ["value", "expectedVersion"],
  "additionalProperties": false
}
