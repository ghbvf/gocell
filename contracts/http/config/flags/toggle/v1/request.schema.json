{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "http.config.flags.toggle.v1.request",
  "type": "object",
  "required": ["enabled", "expectedVersion"],
  "properties": {
    "enabled": { "type": "boolean" },
    "expectedVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "Compare-and-swap guard. Must equal the flag's current version; mismatch returns 409 ERR_VERSION_CONFLICT."
    }
  },
  "additionalProperties": false
}
