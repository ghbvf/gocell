{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "http.config.flags.list.v1.response",
  "type": "object",
  "required": ["data", "nextCursor", "hasMore"],
  "additionalProperties": false,
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "key", "type", "enabled", "rolloutPercentage"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "key": { "type": "string" },
          "type": { "type": "string", "enum": ["boolean", "percentage"] },
          "enabled": { "type": "boolean" },
          "rolloutPercentage": { "type": "integer", "minimum": 0, "maximum": 100 }
        }
      }
    },
    "nextCursor": { "type": "string" },
    "hasMore": { "type": "boolean" }
  }
}
