{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "http.config.rollback.v1.request",
  "type": "object",
  "properties": {
    "version": { "type": "integer", "minimum": 1, "maximum": 99999 },
    "expectedVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "Compare-and-swap guard. Must equal the entry's current version before rollback; mismatch returns 409 ERR_VERSION_CONFLICT."
    }
  },
  "required": ["version", "expectedVersion"],
  "additionalProperties": false
}
