{{template "header" .}}

import (
	"context"
{{- if .Subscriptions }}
	"fmt"
{{- end }}

	"github.com/ghbvf/gocell/kernel/cell"
	"github.com/ghbvf/gocell/kernel/metadata"
{{- range .Subscriptions }}
	{{.SubscriptionAlias}} "{{.SubscriptionPackage}}"
{{- end }}
)

var _ cell.Cell = (*{{.StructName}})(nil)

// cellMeta is the canonical metadata literal projected from cell.yaml.
// loadCellMetadata returns the package-scope pointer; cell.go's constructor
// passes it to cell.MustNewBaseCell which deep-copies the value so callers
// cannot mutate the generated literal.
var cellMeta = &metadata.CellMeta{
	ID:               {{ printf "%q" .MetadataLiteral.ID }},
	Type:             {{ printf "%q" .MetadataLiteral.Type }},
	ConsistencyLevel: {{ printf "%q" .MetadataLiteral.ConsistencyLevel }},
	DurabilityMode:   {{ printf "%q" .MetadataLiteral.DurabilityMode }},
	Owner:            metadata.OwnerMeta{Team: {{ printf "%q" .MetadataLiteral.OwnerTeam }}, Role: {{ printf "%q" .MetadataLiteral.OwnerRole }}},
	Schema:           metadata.SchemaMeta{Primary: {{ printf "%q" .MetadataLiteral.SchemaPrimary }}},
	Verify: metadata.CellVerifyMeta{Smoke: []string{
{{- range .MetadataLiteral.VerifySmoke }}
		{{ printf "%q" . }},
{{- end }}
	}},
	GoStructName: metadata.MustNewGoIdentifier({{ printf "%q" .MetadataLiteral.GoStructName }}),
}

func loadCellMetadata() *metadata.CellMeta { return cellMeta }

//nolint:gocognit // generated code: complexity intrinsic to cell's subscribe count
func (c *{{.StructName}}) Init(ctx context.Context, reg cell.Registry) error {
	if err := c.BaseCell.Init(ctx, reg); err != nil {
		return err
	}
	// initInternal: hand-written init hook (permanent K#04 convention; implement in cell.go)
	if err := c.initInternal(ctx, reg); err != nil {
		return err
	}
{{ range .RouteGroups }}
	reg.RouteGroup(cell.RouteGroup{
		Listener: {{ .ListenerConst }},
		Prefix:   {{ printf "%q" .Prefix }},
		Register: func(mux cell.RouteMux) error {
			var firstErr error
			captureErr := func(err error) {
				if err != nil && firstErr == nil {
					firstErr = err
				}
			}
{{- range .SubRoutes }}
{{- if .SubPath }}
			mux.Route({{ printf "%q" .SubPath }}, func(s cell.RouteMux) {
{{- range .Mounts }}
				captureErr(c.{{ .HandlerField }}.{{ .Method }}(s))
{{- end }}
			})
{{- else }}
{{- range .Mounts }}
			captureErr(c.{{ .HandlerField }}.{{ .Method }}(mux))
{{- end }}
{{- end }}
{{- end }}
			return firstErr
		},
	})
{{ end }}
{{- range .Subscriptions }}
	if err := {{.SubscriptionAlias}}.NewSubscription({{.HandlerExpr}}, {{ if .ConsumerGroup }}{{ printf "%q" .ConsumerGroup }}{{ else }}{{ printf "%q" $.ConsumerGroupDefault }}{{ end }}, {{ printf "%q" .SliceID }}).Mount(reg); err != nil {
		return fmt.Errorf({{ printf "%q" (printf "%s: subscribe %s: %%w" $.CellID .ContractID) }}, err)
	}
{{ end }}
	return nil
}
