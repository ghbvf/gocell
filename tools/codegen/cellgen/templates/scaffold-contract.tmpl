{{define "contract-yaml-http"}}id: {{.ContractID}}
kind: http
ownerCell: {{.CellID}}
consistencyLevel: L1
lifecycle: draft
endpoints:
  server: {{.CellID}}
  clients: []
  http:
    method: POST
    path: /api/v1/{{.CellID}}/example
    successStatus: 200
    auth:
      public: false
    responses:
      400:
        description: "Bad request — malformed JSON body or invalid input"
        schemaRef: "../../../../shared/errors/error-response-v1.schema.json"
      500:
        description: "Internal server error — unexpected failure"
        schemaRef: "../../../../shared/errors/error-response-v1.schema.json"
schemaRefs:
  request: request.schema.json
  response: response.schema.json
{{end}}

{{define "contract-yaml-event"}}id: {{.ContractID}}
kind: event
ownerCell: {{.CellID}}
consistencyLevel: L2
lifecycle: active
endpoints:
  publisher: {{.CellID}}
  subscribers: []
schemaRefs:
  payload: payload.schema.json
  headers: headers.schema.json
replayable: true
idempotencyKey: event_id
deliverySemantics: at-least-once
{{end}}

{{define "request-schema"}}{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "{{.CellID}}.example.request",
  "type": "object",
  "additionalProperties": false,
  "required": ["message"],
  "properties": {
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Echo input message"
    }
  }
}
{{end}}

{{define "response-schema"}}{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "{{.CellID}}.example.response",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "description": "Echoed message"
    }
  }
}
{{end}}

{{define "payload-schema"}}{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "{{.CellID}}.example.payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "message"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Idempotency key"
    },
    "message": {
      "type": "string",
      "description": "Event message"
    }
  }
}
{{end}}

{{define "headers-schema"}}{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "{{.CellID}}.example.headers",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Idempotency key"
    }
  }
}
{{end}}
