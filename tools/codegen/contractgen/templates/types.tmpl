{{template "contractHeader" .}}

package {{.PackageName}}
{{- if eq .Kind "http"}}

import (
	"context"
	"encoding/json"
	"log/slog"
	"net/http"

	"github.com/ghbvf/gocell/pkg/errcode"
	"github.com/ghbvf/gocell/pkg/httputil"
)
{{- end}}
{{range .DTOs}}
{{- if .Doc}}// {{.Name}} — {{.Doc}}
{{- else}}// {{.Name}} is a generated DTO for contract {{$.ContractID}}.
{{- end}}
type {{.Name}} struct {
{{- range .Fields}}
{{- if .Doc}}
	// {{.Doc}}
{{- end}}
	{{.Name}} {{.GoType}} `json:"{{.JSONTag}}"`
{{- end}}
}
{{end}}
{{- if and (eq .Kind "http") .Endpoint.Responses}}

// {{.Endpoint.HandlerMethod}}ResponseObject is the typed response envelope for
// {{.ContractID}}. Service.{{.Endpoint.HandlerMethod}} must return one of the
// {{.Endpoint.HandlerMethod}}{Status}{Suffix} structs declared below; the
// generated handler dispatches via the unexported method, which keeps the
// implementation set closed to types declared in this package.
//
// ref: oapi-codegen pkg/codegen/templates/strict/strict-responses.tmpl@main
type {{.Endpoint.HandlerMethod}}ResponseObject interface {
	visit{{.Endpoint.HandlerMethod}}Response(ctx context.Context, w http.ResponseWriter) error
}
{{range .Endpoint.Responses}}
{{- if .IsError}}
// {{.GoTypeName}} renders an HTTP {{.Status}} error response.
// Body carries an errcode.Error whose Kind/Code/Message/Details follow the
// canonical wire schema in contracts/shared/errors/error-response-v1.schema.json
// (5xx Details are stripped by Error.MarshalJSON; Internal never serializes).
type {{.GoTypeName}} struct {
	Body errcode.Error
}

func (r {{.GoTypeName}}) visit{{$.Endpoint.HandlerMethod}}Response(ctx context.Context, w http.ResponseWriter) error {
	httputil.WriteErrorWithStatus(ctx, w, {{.Status}}, &r.Body)
	return nil
}
{{- else if eq .GoTypeName (printf "%s%dNoContentResponse" $.Endpoint.HandlerMethod .Status)}}
// {{.GoTypeName}} renders an HTTP {{.Status}} No Content success response.
// The success status carries no body; this struct is a marker so the
// typed-envelope set covers the success case uniformly with errors.
type {{.GoTypeName}} struct{}

func (r {{.GoTypeName}}) visit{{$.Endpoint.HandlerMethod}}Response(ctx context.Context, w http.ResponseWriter) error {
	w.WriteHeader({{.Status}})
	return nil
}
{{- else}}
// {{.GoTypeName}} renders an HTTP {{.Status}} success response.
// Marshals the underlying Response DTO as a JSON body.
type {{.GoTypeName}} Response

func (r {{.GoTypeName}}) visit{{$.Endpoint.HandlerMethod}}Response(ctx context.Context, w http.ResponseWriter) error {
	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader({{.Status}})
	if err := json.NewEncoder(w).Encode(Response(r)); err != nil {
		slog.ErrorContext(ctx, "{{$.ContractID}}: encode {{.GoTypeName}} body", slog.Any("error", err))
		return err
	}
	return nil
}
{{- end}}
{{end}}
{{- end}}
