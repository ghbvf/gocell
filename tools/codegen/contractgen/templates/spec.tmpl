{{template "contractHeader" .}}

package {{.PackageName}}

import (
	"github.com/ghbvf/gocell/kernel/cellvocab"
	"github.com/ghbvf/gocell/kernel/contractspec"
)

// spec is the ContractSpec for {{.ContractID}}.
// Private — callers must use NewSubscription.Mount(reg) to register this event.
var spec = contractspec.ContractSpec{
	ID:        {{printf "%q" .ContractID}},
	Kind:      cellvocab.ContractEvent,
	Transport: "amqp",
	Topic:     {{printf "%q" .Event.Topic}},
}
