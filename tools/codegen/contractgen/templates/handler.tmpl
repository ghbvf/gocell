{{template "contractHeader" .}}

package {{.PackageName}}

import (
	"net/http"
{{- if and (not .Endpoint.IsPagination) (hasQueryNumeric .Endpoint.QueryParams)}}
	"strconv"
{{- end}}

	"github.com/ghbvf/gocell/kernel/cell"
	"github.com/ghbvf/gocell/kernel/wrapper"
{{- if needsErrcode .}}
	"github.com/ghbvf/gocell/pkg/errcode"
{{- end}}
	"github.com/ghbvf/gocell/pkg/httputil"
	"github.com/ghbvf/gocell/runtime/auth"
)

var contractSpec = wrapper.ContractSpec{
	ID:        "{{.ContractID}}",
	Kind:      "http",
	Transport: "http",
	Method:    "{{.Endpoint.Method}}",
	Path:      "{{.Endpoint.Path}}",
}

// Handler wires HTTP decode/encode + auth.Mount for {{.ContractID}}.
type Handler struct {
	svc    Service
	policy auth.Policy
}

// NewHandler creates a Handler for {{.ContractID}}.
// policy may be nil — auth.Mount treats nil as "no per-route authorization guard";
// use auth.PublicPolicy for unauthenticated public endpoints or supply a real policy.
func NewHandler(svc Service, policy auth.Policy) *Handler {
	return &Handler{svc: svc, policy: policy}
}

// ServeHTTP implements http.Handler so *Handler can be used directly in tests
// and as an http.Handler argument without wrapping.
func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {
	h.handle(w, r)
}

// RegisterRoutes mounts the handler on mux via auth.Mount.
// Uses http.HandlerFunc(h.handle) so governance CH-04/CH-05 AST scans can
// resolve the handler function body via the Contract→Handler correlation.
func (h *Handler) RegisterRoutes(mux cell.RouteHandler) error {
	return auth.Mount(mux, auth.Route{
		Contract: contractSpec,
		Handler:  http.HandlerFunc(h.handle),
		Policy:   h.policy,
	})
}

func (h *Handler) handle(w http.ResponseWriter, r *http.Request) {
	req := &Request{}
{{- range .Endpoint.PathParams}}
{{- if eq .Format "uuid"}}
	{
		v, ok := httputil.ParseUUIDPathParam(w, r, "{{.Name}}")
		if !ok {
			return
		}
		req.{{.GoName}} = v
	}
{{- else}}
	{
		v := r.PathValue("{{.Name}}")
{{- if hasMinLength .MinLength}}
		if len(v) < {{derefInt .MinLength}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: value too short"))
			return
		}
{{- end}}
{{- if hasMaxLength .MaxLength}}
		if len(v) > {{derefInt .MaxLength}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: value too long"))
			return
		}
{{- end}}
		req.{{.GoName}} = v
	}
{{- end}}
{{- end}}
{{- if .Endpoint.HasBody}}
	if err := httputil.DecodeJSONStrict(r, req, httputil.DefaultDecodeJSONLimit); err != nil {
		httputil.WriteError(r.Context(), w, err)
		return
	}
{{- if hasBodyValidation .DTOs}}
{{- range .DTOs}}{{if eq .Name "Request"}}{{range .Fields}}{{if isBodyField .}}
{{- if hasMinLength .MinLength}}
	if len(req.{{.Name}}) < {{derefInt .MinLength}} {
		httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.JSONTag}}: value too short"))
		return
	}
{{- end}}
{{- if hasMaxLength .MaxLength}}
	if len(req.{{.Name}}) > {{derefInt .MaxLength}} {
		httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.JSONTag}}: value too long"))
		return
	}
{{- end}}
{{- if hasMinimum .Minimum}}
	if req.{{.Name}} < {{derefInt64 .Minimum}} {
		httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.JSONTag}}: value below minimum"))
		return
	}
{{- end}}
{{- if hasMaximum .Maximum}}
	if req.{{.Name}} > {{derefInt64 .Maximum}} {
		httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.JSONTag}}: value above maximum"))
		return
	}
{{- end}}
{{- end}}{{end}}{{end}}{{end}}
{{- end}}
{{- else if .Endpoint.IsPagination}}
	page, err := httputil.ParsePageParams(r)
	if err != nil {
		httputil.WriteError(r.Context(), w, err)
		return
	}
	req.Cursor = page.Cursor
	req.Limit = int64(page.Limit)
{{- else}}
{{- range .Endpoint.QueryParams}}
{{- if eq .GoType "string"}}
	req.{{.GoName}} = r.URL.Query().Get("{{.Name}}")
{{- if .Required}}
	if req.{{.GoName}} == "" {
		httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}} is required"))
		return
	}
{{- end}}
{{- if hasMinLength .MinLength}}
	if req.{{.GoName}} != "" && len(req.{{.GoName}}) < {{derefInt .MinLength}} {
		httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: value too short"))
		return
	}
{{- end}}
{{- if hasMaxLength .MaxLength}}
	if req.{{.GoName}} != "" && len(req.{{.GoName}}) > {{derefInt .MaxLength}} {
		httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: value too long"))
		return
	}
{{- end}}
{{- else if eq .GoType "int64"}}
{{- if .Required}}
	{
		raw{{.GoName}} := r.URL.Query().Get("{{.Name}}")
		if raw{{.GoName}} == "" {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}} is required"))
			return
		}
		v, err := strconv.ParseInt(raw{{.GoName}}, 10, 64)
		if err != nil {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: must be an integer"))
			return
		}
{{- if hasMinimum .Minimum}}
		if v < {{derefInt64 .Minimum}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: value below minimum"))
			return
		}
{{- end}}
{{- if hasMaximum .Maximum}}
		if v > {{derefInt64 .Maximum}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: value above maximum"))
			return
		}
{{- end}}
		req.{{.GoName}} = v
	}
{{- else}}
	if raw := r.URL.Query().Get("{{.Name}}"); raw != "" {
		v, err := strconv.ParseInt(raw, 10, 64)
		if err != nil {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: must be an integer"))
			return
		}
{{- if hasMinimum .Minimum}}
		if v < {{derefInt64 .Minimum}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: value below minimum"))
			return
		}
{{- end}}
{{- if hasMaximum .Maximum}}
		if v > {{derefInt64 .Maximum}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: value above maximum"))
			return
		}
{{- end}}
		req.{{.GoName}} = v
	}
{{- end}}
{{- else if eq .GoType "float64"}}
	if raw := r.URL.Query().Get("{{.Name}}"); raw != "" {
		v, err := strconv.ParseFloat(raw, 64)
		if err != nil {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: must be a number"))
			return
		}
		req.{{.GoName}} = v
	}
{{- else if eq .GoType "bool"}}
	if raw := r.URL.Query().Get("{{.Name}}"); raw != "" {
		v, err := strconv.ParseBool(raw)
		if err != nil {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed, "{{.Name}}: must be a boolean"))
			return
		}
		req.{{.GoName}} = v
	}
{{- end}}
{{- end}}
{{- end}}
	resp, err := h.svc.{{.Endpoint.HandlerMethod}}(r.Context(), req)
	if err != nil {
		httputil.WriteError(r.Context(), w, err)
		return
	}
{{- if .Endpoint.NoContent}}
	w.WriteHeader(http.StatusNoContent)
	_ = resp
{{- else}}
	httputil.WriteJSON(w, {{.Endpoint.SuccessCode}}, resp)
{{- end}}
}
