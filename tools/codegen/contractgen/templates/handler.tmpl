{{- /*
queryParamParse renders the inline parsing block for one query parameter.
Used by both the Pagination.ExtraQueryParams branch (when cursor/limit are
already handled by httputil.ParsePageParams) and the non-pagination branch
(plain per-param parse). Single source so the constraint check + error
envelope shape stays consistent across the entire HTTP surface
(PR-V1-CONTRACT-TYPED-RESPONSE-ENVELOPE F4 absorb).
*/ -}}
{{- define "queryParamParse" -}}
{{- if eq .GoType "string"}}
	req.{{.GoName}} = r.URL.Query().Get("{{.Name}}")
{{- if .Required}}
	if req.{{.GoName}} == "" {
		httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
			"validation: required field missing",
			errcode.WithDetails(slog.String("field", "{{.Name}}"))))
		return
	}
{{- end}}
{{- if hasMinLength .MinLength}}
	if req.{{.GoName}} != "" && len(req.{{.GoName}}) < {{derefInt .MinLength}} {
		httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
			"validation: invalid request parameter",
			errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "invalid"))))
		return
	}
{{- end}}
{{- if hasMaxLength .MaxLength}}
	if len(req.{{.GoName}}) > {{derefInt .MaxLength}} {
		httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
			"validation: invalid request parameter",
			errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "invalid"))))
		return
	}
{{- end}}
{{- else if eq .GoType "int64"}}
{{- if .Required}}
	{
		raw{{.GoName}} := r.URL.Query().Get("{{.Name}}")
		if raw{{.GoName}} == "" {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: required field missing",
				errcode.WithDetails(slog.String("field", "{{.Name}}"))))
			return
		}
		v, err := strconv.ParseInt(raw{{.GoName}}, 10, 64)
		if err != nil {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: invalid request parameter",
				errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "must be an integer"))))
			return
		}
{{- if hasMinimum .Minimum}}
		if v < {{derefInt64 .Minimum}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: invalid request parameter",
				errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "invalid"))))
			return
		}
{{- end}}
{{- if hasMaximum .Maximum}}
		if v > {{derefInt64 .Maximum}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: invalid request parameter",
				errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "invalid"))))
			return
		}
{{- end}}
		req.{{.GoName}} = v
	}
{{- else}}
	if raw := r.URL.Query().Get("{{.Name}}"); raw != "" {
		v, err := strconv.ParseInt(raw, 10, 64)
		if err != nil {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: invalid request parameter",
				errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "must be an integer"))))
			return
		}
{{- if hasMinimum .Minimum}}
		if v < {{derefInt64 .Minimum}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: invalid request parameter",
				errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "invalid"))))
			return
		}
{{- end}}
{{- if hasMaximum .Maximum}}
		if v > {{derefInt64 .Maximum}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: invalid request parameter",
				errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "invalid"))))
			return
		}
{{- end}}
		req.{{.GoName}} = v
	}
{{- end}}
{{- else if eq .GoType "float64"}}
	if raw := r.URL.Query().Get("{{.Name}}"); raw != "" {
		v, err := strconv.ParseFloat(raw, 64)
		if err != nil {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: invalid request parameter",
				errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "must be a number"))))
			return
		}
		req.{{.GoName}} = v
	}
{{- else if eq .GoType "bool"}}
	if raw := r.URL.Query().Get("{{.Name}}"); raw != "" {
		v, err := strconv.ParseBool(raw)
		if err != nil {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: invalid request parameter",
				errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "must be a boolean"))))
			return
		}
		req.{{.GoName}} = v
	}
{{- end}}
{{- end -}}
{{template "contractHeader" .}}

package {{.PackageName}}

import (
	"log/slog"
	"net/http"
{{- if .RequestSchemaJSON}}
	"bytes"
	"io"
{{- end}}
{{- if needsStrconv .}}
	"strconv"
{{- end}}

	"github.com/ghbvf/gocell/kernel/cell"
	"github.com/ghbvf/gocell/kernel/wrapper"
	"github.com/ghbvf/gocell/pkg/errcode"
	"github.com/ghbvf/gocell/pkg/httputil"
	"github.com/ghbvf/gocell/runtime/auth"
{{- if .RequestSchemaJSON}}
	"github.com/ghbvf/gocell/runtime/http/schemavalidate"
{{- end}}
)

var contractSpec = wrapper.ContractSpec{
	ID:        "{{.ContractID}}",
	Kind:      "http",
	Transport: "http",
	Method:    "{{.Endpoint.Method}}",
	Path:      "{{.Endpoint.Path}}",
{{- if .Endpoint.Clients}}
	Clients: []string{ {{- range $i, $c := .Endpoint.Clients}}{{if $i}}, {{end}}"{{$c}}"{{end}} },
{{- end}}
}

{{- if .RequestSchemaJSON}}
// requestSchemaJSON is the embedded request schema for runtime validation.
// Compiled once at handler construction time by schemavalidate.NewValidator.
var requestSchemaJSON = []byte({{quoteGoString .RequestSchemaJSON}})
{{- end}}

// Handler wires HTTP decode/encode + auth.Mount for {{.ContractID}}.
type Handler struct {
	svc    Service
{{- if and (not .Endpoint.AuthPublic) (not .Endpoint.AuthBootstrap)}}
	policy auth.Policy
{{- end}}
{{- if .Endpoint.AuthBootstrap}}
	bootstrapAuth func(http.Handler) http.Handler
{{- end}}
{{- if .RequestSchemaJSON}}
	requestValidator schemavalidate.Validator
{{- end}}
}

{{- if .Endpoint.AuthPublic}}
// NewHandler creates a Handler for {{.ContractID}}.
// This endpoint is Public (JWT-exempt); no policy argument is accepted.
// auth.Route{Public: true} is emitted by RegisterRoutes so the listener
// auth middleware skips JWT verification for this route.
func NewHandler(svc Service) *Handler {
	h := &Handler{svc: svc}
{{- if .RequestSchemaJSON}}
	v, err := schemavalidate.NewValidator(requestSchemaJSON)
	if err != nil {
		panic(errcode.Assertion("generated handler {{.ContractID}}: schema compile failed: %v (codegen invariant violation; regenerate via gocell generate contract --all)", err))
	}
	h.requestValidator = v
{{- end}}
	return h
}
{{- else if .Endpoint.AuthBootstrap}}
// NewHandler creates a Handler for {{.ContractID}}.
//
// This endpoint is Bootstrap (HTTP Basic Auth via GOCELL_BOOTSTRAP_ADMIN_* env).
// bootstrapAuth is REQUIRED — it is the per-route replacement authentication
// middleware (typically runtime/auth.NewBootstrapMiddleware wired by the
// composition root). auth.Route{BootstrapAuth: bootstrapAuth} is emitted by
// RegisterRoutes; the listener auth middleware skips JWT verification for this
// route while bootstrapAuth runs in its place.
//
// Passing a nil bootstrapAuth panics at construction time — there is no
// "declared bootstrap but no auth wired" intermediate state. FMT-28 restricts
// auth.bootstrap:true to setup/admin contracts only.
func NewHandler(svc Service, bootstrapAuth func(http.Handler) http.Handler) *Handler {
	if bootstrapAuth == nil {
		// B-class assertion: argument-contract violation (composition-root must inject
		// runtime/auth.NewBootstrapMiddleware). errcode.Assertion routes through the
		// kernel recover middleware (500 + structured log) instead of a bare panic so
		// PANIC-REGISTERED-01 archtest stays clean across the entire generator surface.
		panic(errcode.Assertion("generated handler {{.ContractID}}: bootstrapAuth must not be nil (auth.bootstrap:true contracts require a per-route replacement authenticator; composition root must inject runtime/auth.NewBootstrapMiddleware)"))
	}
	h := &Handler{svc: svc, bootstrapAuth: bootstrapAuth}
{{- if .RequestSchemaJSON}}
	v, err := schemavalidate.NewValidator(requestSchemaJSON)
	if err != nil {
		panic(errcode.Assertion("generated handler {{.ContractID}}: schema compile failed: %v (codegen invariant violation; regenerate via gocell generate contract --all)", err))
	}
	h.requestValidator = v
{{- end}}
	return h
}
{{- else}}
// NewHandler creates a Handler for {{.ContractID}}.
// policy may be nil — auth.Mount treats nil as "no per-route authorization guard";
// supply a real policy (e.g. auth.AnyRole, auth.SelfOr) to enforce access control.
func NewHandler(svc Service, policy auth.Policy) *Handler {
	h := &Handler{svc: svc, policy: policy}
{{- if .RequestSchemaJSON}}
	v, err := schemavalidate.NewValidator(requestSchemaJSON)
	if err != nil {
		panic(errcode.Assertion("generated handler {{.ContractID}}: schema compile failed: %v (codegen invariant violation; regenerate via gocell generate contract --all)", err))
	}
	h.requestValidator = v
{{- end}}
	return h
}
{{- end}}

// ServeHTTP implements http.Handler so *Handler can be used directly in tests
// and as an http.Handler argument without wrapping.
func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {
	h.handle(w, r)
}

// RegisterRoutes mounts the handler on mux via auth.Mount.
// Uses http.HandlerFunc(h.handle) so governance CH-04/CH-05 AST scans can
// resolve the handler function body via the Contract→Handler correlation.
func (h *Handler) RegisterRoutes(mux cell.RouteHandler) error {
	return auth.Mount(mux, auth.Route{
		Contract: contractSpec,
		Handler:  http.HandlerFunc(h.handle),
{{- if .Endpoint.AuthPublic}}
		Public: true,
{{- else if .Endpoint.AuthBootstrap}}
		BootstrapAuth: h.bootstrapAuth,
{{- else if .Endpoint.AuthPasswordResetExempt}}
		Policy:              h.policy,
		PasswordResetExempt: true,
{{- else}}
		Policy: h.policy,
{{- end}}
	})
}

func (h *Handler) handle(w http.ResponseWriter, r *http.Request) {
	req := &Request{}
{{- range .Endpoint.PathParams}}
{{- if eq .Format "uuid"}}
	{
		v, ok := httputil.ParseUUIDPathParam(w, r, "{{.Name}}")
		if !ok {
			return
		}
		req.{{.GoName}} = v
	}
{{- else}}
	{
		v := r.PathValue("{{.Name}}")
{{- if hasMinLength .MinLength}}
		if len(v) < {{derefInt .MinLength}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: invalid request parameter",
				errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "invalid"))))
			return
		}
{{- end}}
{{- if hasMaxLength .MaxLength}}
		if len(v) > {{derefInt .MaxLength}} {
			httputil.WriteError(r.Context(), w, errcode.New(errcode.KindInvalid, errcode.ErrValidationFailed,
				"validation: invalid request parameter",
				errcode.WithDetails(slog.String("field", "{{.Name}}"), slog.String("reason", "invalid"))))
			return
		}
{{- end}}
		req.{{.GoName}} = v
	}
{{- end}}
{{- end}}
{{- if .Endpoint.HasBody}}
{{- if .RequestSchemaJSON}}
	bodyBytes, err := io.ReadAll(io.LimitReader(r.Body, httputil.DefaultDecodeJSONLimit+1))
	if err != nil {
		httputil.WriteError(r.Context(), w, err)
		return
	}
	r.Body = io.NopCloser(bytes.NewReader(bodyBytes))
{{- end}}
	if err := httputil.DecodeJSONStrict(r, req, httputil.DefaultDecodeJSONLimit); err != nil {
		httputil.WriteError(r.Context(), w, err)
		return
	}
{{- if .RequestSchemaJSON}}
	if h.requestValidator != nil {
		if err := h.requestValidator.Validate(r.Context(), bodyBytes); err != nil {
			schemavalidate.WriteValidationError(r.Context(), w, err)
			return
		}
	}
{{- end}}
{{- end}}
{{- if .Endpoint.Pagination}}
	page, err := httputil.ParsePageParams(r)
	if err != nil {
		httputil.WriteError(r.Context(), w, err)
		return
	}
	req.Cursor = page.Cursor
	req.Limit = int64(page.Limit)
{{- range .Endpoint.Pagination.ExtraQueryParams}}
{{template "queryParamParse" .}}
{{- end}}
{{- else}}
{{- range .Endpoint.QueryParams}}
{{template "queryParamParse" .}}
{{- end}}
{{- end}}
	resp, err := h.svc.{{.Endpoint.HandlerMethod}}(r.Context(), req)
	if err != nil {
		httputil.WriteError(r.Context(), w, err)
		return
	}
	if resp == nil {
		// Service contract violation: returned nil response without error. CH-06
		// enforces the typed-struct ↔ contract.yaml bijection statically, so the
		// only way this branch fires is a service implementation bug. Use
		// errcode.Assertion (B-class panic) so the kernel recover middleware
		// converts to 500 + structured Error log without forcing every contract
		// to declare 500 under endpoints.http.responses (CH-04 only flags
		// handler-emitted statuses that have no recover backstop).
		panic(errcode.Assertion("generated handler {{.ContractID}}: service returned nil response without error (typed envelope contract violation)"))
	}
	// types_gen.go's encode/write paths already log via slog.ErrorContext on
	// failure (with request_id/trace_id correlation). Headers/body may already
	// be flushed at this point so there is no recovery branch — surface the
	// outcome on the handler-level slog so access-log + trace span see the
	// truncated response and metrics middleware can record the failure.
	if visitErr := resp.visit{{.Endpoint.HandlerMethod}}Response(r.Context(), w); visitErr != nil {
		slog.ErrorContext(r.Context(), "{{.ContractID}}: typed response visit failed",
			slog.Any("error", visitErr))
	}
}
