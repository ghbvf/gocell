{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "http.item.details.v1.response",
  "type": "object",
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdAt"]
    }
  },
  "required": ["data"]
}
