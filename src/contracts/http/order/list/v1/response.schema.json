{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "http.order.list.v1.response",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "item": { "type": "string" },
          "status": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "item", "status", "createdAt"]
      }
    },
    "nextCursor": { "type": "string" },
    "hasMore": { "type": "boolean" }
  },
  "required": ["data", "hasMore"]
}
