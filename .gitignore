# Generated (tracked selectively)
# generated/ files are committed but regenerated by `gocell generate`
bak/

# cmd/corebundle/catalog_gen.go is generated by `go generate ./cmd/corebundle/`.
# Not committed because go/packages.Load reports slightly different .Imports
# across macOS and Linux for production packages whose internal _test.go
# imports diverge from production imports (a known go/packages quirk).
# Committing the file guarantees byte-equal drift on every cross-platform CI
# run. Each consumer (CI, local build, prod build) generates its own copy
# before `go build ./cmd/corebundle/`. See docs/guides/devtools-catalog.md.
cmd/corebundle/catalog_gen.go
