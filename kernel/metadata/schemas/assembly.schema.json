{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gocell.dev/schemas/assembly.schema.json",
  "title": "GoCell Assembly Descriptor",
  "description": "Defines an Assembly, the physical packaging unit. K#10: minimal required = id+cells+owner; build fields are derived from cell.yaml type when omitted.",
  "type": "object",
  "required": ["id", "cells", "owner"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique assembly identifier. Must equal the directory name under assemblies/.",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "cells": {
      "type": "array",
      "description": "List of cell ids included in this assembly.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "owner": {
      "type": "object",
      "description": "Team responsible for this assembly.",
      "required": ["team", "role"],
      "additionalProperties": false,
      "properties": {
        "team": {
          "type": "string",
          "description": "Team name."
        },
        "role": {
          "type": "string",
          "description": "Role identifier."
        }
      }
    },
    "build": {
      "type": "object",
      "description": "Build configuration for the assembly. All fields optional; defaults are derived.",
      "additionalProperties": false,
      "properties": {
        "entrypoint": {
          "type": "string",
          "description": "Path to main.go (default: cmd/{id}/main.go)"
        },
        "binary": {
          "type": "string",
          "description": "Output binary name (default: assembly id)"
        },
        "deployTemplate": {
          "type": "string",
          "description": "Deployment template identifier.",
          "enum": ["k8s", "compose", "binary"],
          "default": "k8s"
        }
      }
    }
  }
}
