{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "gocell",
          "version": "test-1.0.0",
          "informationUri": "https://github.com/ghbvf/gocell",
          "rules": [
            {
              "id": "MSG-01",
              "shortDescription": {
                "text": "包含 \"引号\" 和 换行\n以及 emoji 🚀"
              },
              "defaultConfiguration": {
                "level": "error"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "MSG-01",
          "level": "error",
          "message": {
            "text": "包含 \"引号\" 和 换行\n以及 emoji 🚀 (field: 名称)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "cells/%E4%B8%AD%E6%96%87/cell.yaml",
                  "uriBaseId": "SRCROOT"
                },
                "region": {
                  "startLine": 1,
                  "startColumn": 1
                }
              }
            }
          ]
        }
      ],
      "originalUriBaseIds": {
        "SRCROOT": {}
      }
    }
  ]
}
