{
  "_comment": "v1.0 placeholder — connect to Prometheus-compatible datasource",
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Cell Health (Up/Down)",
      "description": "Shows whether the Cell is up (1) or down (0) based on the health check endpoint.",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "up{job=\"${cell_id}\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "title": "Outbox Relay Throughput",
      "description": "Relay processing rates by outcome. Shows published, retried, and dead-lettered message rates.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(gocell_outbox_relayed_total{cell=\"${cell_id}\", outcome=\"published\"}[5m])",
          "legendFormat": "published (msg/s)",
          "refId": "A"
        },
        {
          "expr": "rate(gocell_outbox_relayed_total{cell=\"${cell_id}\", outcome=\"retried\"}[5m])",
          "legendFormat": "retried (msg/s)",
          "refId": "B"
        },
        {
          "expr": "rate(gocell_outbox_relayed_total{cell=\"${cell_id}\", outcome=\"dead\"}[5m])",
          "legendFormat": "dead (msg/s)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "title": "HTTP Request Latency (p50 / p95 / p99)",
      "description": "Request latency percentiles for the Cell's HTTP endpoints.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gocell_http_request_duration_seconds_bucket{cell=\"${cell_id}\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gocell_http_request_duration_seconds_bucket{cell=\"${cell_id}\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gocell_http_request_duration_seconds_bucket{cell=\"${cell_id}\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5,
            "pointSize": 5,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "unit": "s"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "title": "HTTP Request Rate & Error Rate",
      "description": "Total request throughput and 5xx error rate.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 4,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(gocell_http_requests_total{cell=\"${cell_id}\"}[5m]))",
          "legendFormat": "total req/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(gocell_http_requests_total{cell=\"${cell_id}\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx errors/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "lineWidth": 2
          },
          "unit": "reqps"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "title": "Dead-Letter Event Volume",
      "description": "Rate of messages entering the dead-letter state. Non-zero rates require investigation. Includes pollOnce failures only; reclaimStale dead transitions are tracked separately via gocell_outbox_reclaimed_total.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 5,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "increase(gocell_outbox_relayed_total{cell=\"${cell_id}\", outcome=\"dead\"}[5m])",
          "legendFormat": "dead events (5m)",
          "refId": "A"
        },
        {
          "expr": "increase(gocell_outbox_reclaimed_total{cell=\"${cell_id}\"}[5m])",
          "legendFormat": "reclaimed (5m, may include dead)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "lineWidth": 1
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["gocell", "cell-health"],
  "templating": {
    "list": [
      {
        "name": "cell_id",
        "label": "Cell ID",
        "description": "The GoCell Cell identifier to monitor",
        "type": "textbox",
        "current": {
          "value": "access-core"
        }
      },
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus Datasource",
        "description": "Prometheus-compatible datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "GoCell — ${cell_id} Dashboard",
  "uid": "gocell-cell-template",
  "version": 1
}
