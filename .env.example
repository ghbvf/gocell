# PostgreSQL
GOCELL_PG_DSN=postgres://gocell:gocell_dev@localhost:5432/gocell_dev?sslmode=disable
GOCELL_PG_MAX_CONNS=10
GOCELL_PG_IDLE_TIMEOUT=5m
GOCELL_PG_MAX_LIFETIME=1h

# Redis
GOCELL_REDIS_ADDR=localhost:6379
GOCELL_REDIS_PASSWORD=
GOCELL_REDIS_DB=0

# RabbitMQ
GOCELL_AMQP_URL=amqp://gocell:gocell_dev@localhost:5672/

# MinIO (S3)
GOCELL_S3_ENDPOINT=localhost:9000
GOCELL_S3_ACCESS_KEY=gocell
GOCELL_S3_SECRET_KEY=gocell_dev_secret
GOCELL_S3_BUCKET=gocell-dev
GOCELL_S3_USE_SSL=false

# JWT (active signing key pair)
GOCELL_JWT_PRIVATE_KEY=
GOCELL_JWT_PUBLIC_KEY=

# JWT key rotation (optional — set during rotation window)
# GOCELL_JWT_PREV_PUBLIC_KEY=
# GOCELL_JWT_PREV_KEY_EXPIRES=2026-04-12T00:00:00Z

# Service token HMAC (min 32 bytes)
GOCELL_SERVICE_SECRET=
# GOCELL_SERVICE_SECRET_PREVIOUS=

# Audit HMAC signing key (required in GOCELL_ADAPTER_MODE=real)
GOCELL_HMAC_KEY=

# Cursor codec keys (32 bytes each, required in GOCELL_ADAPTER_MODE=real)
GOCELL_AUDIT_CURSOR_KEY=
GOCELL_CONFIG_CURSOR_KEY=

# /readyz?verbose authentication token (required in GOCELL_ADAPTER_MODE=real
# to prevent anonymous exposure of internal cell/dependency topology).
# When unset in dev mode, /readyz?verbose is unauthenticated.
# Scraper must send it as the `X-Readyz-Token` HTTP header.
GOCELL_READYZ_VERBOSE_TOKEN=

# /metrics authentication token (required in GOCELL_ADAPTER_MODE=real to
# prevent anonymous exposure of cell lifecycle signals — cell_id / hook /
# outcome labels reveal internal topology). When unset in dev mode,
# /metrics is unauthenticated.
#
# Scraper must send it as the `X-Metrics-Token` HTTP header. Minimal
# Prometheus scrape config snippet:
#
#   scrape_configs:
#     - job_name: gocell
#       static_configs:
#         - targets: ['gocell.example.internal:8080']
#       metrics_path: /metrics
#       scheme: https
#       authorization:  # Prometheus v2.43+ accepts custom header via relabel
#         type: ''       # leave empty; we use a custom header, not Bearer
#       # Prometheus <v3 requires the following relabel to set a custom
#       # header; v3+ supports `http_headers` natively on the scrape job.
#       params: {}
#       http_headers:
#         X-Metrics-Token: ['${GOCELL_METRICS_TOKEN}']
GOCELL_METRICS_TOKEN=

# Adapter mode: empty/dev (default) or "real" (enforces env-sourced secrets).
# GOCELL_ADAPTER_MODE=

# Admin seed (both must be set together; password is unset from env after read)
# GOCELL_ADMIN_USER=
# GOCELL_ADMIN_PASS=
